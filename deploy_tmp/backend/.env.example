# 服务端口
PORT=4000
# 数据库连接
# 本地开发默认 SQLite:
DATABASE_URL="file:./dev.db"
# 生产 PostgreSQL 示例:
# DATABASE_URL="postgresql://lslife:PASSWORD@127.0.0.1:5432/lslife?schema=public"
# JWT 密钥 (生产必须替换为强随机值)
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="30d"

# ===== 短信服务 (阿里云/腾讯云短信) =====
SMS_PROVIDER="mock"
SMS_ACCESS_KEY=""
SMS_ACCESS_SECRET=""
SMS_SIGN_NAME=""
SMS_TEMPLATE_CODE=""

# ===== 支付 (需持牌第三方; 服务端下单+异步回调) =====
# 微信支付
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_API_V3_KEY=""
WECHAT_NOTIFY_URL=""
# 支付宝
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_NOTIFY_URL=""
# 支付驱动: mock | wechat | alipay
PAY_PROVIDER="mock"

# ===== AI 大模型 (国内合规: 通义/文心/豆包) =====
# 驱动: mock | dashscope | qianfan | doubao
AI_PROVIDER="mock"
AI_API_KEY=""
AI_MODEL="qwen-plus"

# ===== 对象存储 (阿里云 OSS / 腾讯云 COS) =====
OSS_ENDPOINT=""
OSS_BUCKET=""
OSS_ACCESS_KEY=""
OSS_ACCESS_SECRET=""

# 内容审核开关
CONTENT_MODERATION_ENABLED="true"
